# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: enables durable Edge Function processing (server-only, never commit)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI processing: direct image editing replaces visible screenshot text
# in-place. Defaults favor quality and crisp UI text over speed/cost.
# PROCESS_IMAGE_MODEL=gpt-image-2
# PROCESS_IMAGE_QUALITY=high
# PROCESS_IMAGE_SIZE=auto
# PROCESS_IMAGE_OUTPUT_FORMAT=png
# PROCESS_STEP_METADATA_MODEL=gpt-5.5

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
