# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: enables durable Edge Function processing (server-only, never commit)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI processing (defaults: gpt-image-1.5 @ low, ~12s on wide screenshots)
# PROCESS_STEP_RESPONSE_MODEL=gpt-4o-mini
# PROCESS_IMAGE_MODEL=gpt-image-1.5
# PROCESS_IMAGE_QUALITY=low
# For denser UIs where text clarity matters more than speed, try:
# PROCESS_IMAGE_QUALITY=medium
# PROCESS_IMAGE_INPUT_FIDELITY=low
# PROCESS_IMAGE_INPUT_DETAIL=auto
# PROCESS_USE_EDGE_FUNCTION=true
# PROCESS_IMAGE_OUTPUT_FORMAT=png

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
