# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: enables durable Edge Function processing (server-only, never commit)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI processing — AI image regeneration (re-renders the screenshot with
# translated text). Defaults: gpt-image-1 @ high quality, input_fidelity low
# (~55s on wide screenshots). quality "high" is required for crisp small text;
# "medium"/"low" garble dense UI copy. input_fidelity must stay "low" so the
# model re-renders text instead of preserving original glyphs.
# PROCESS_STEP_RESPONSE_MODEL=gpt-4o-mini
# PROCESS_IMAGE_MODEL=gpt-image-1
# PROCESS_IMAGE_QUALITY=high
# PROCESS_IMAGE_INPUT_FIDELITY=low
# PROCESS_IMAGE_INPUT_DETAIL=auto
# PROCESS_IMAGE_OUTPUT_FORMAT=png

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
